---
import type { TenantConfig } from "@config/tenants";

export interface Props {
  tenant: TenantConfig;
  productCount: number;
}

const { tenant, productCount } = Astro.props;
---

<section class="relative overflow-hidden" style="background: linear-gradient(135deg, {tenant.primaryColor}11 0%, {tenant.primaryColor}22 100%)">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
    <div class="max-w-2xl">
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight text-surface-900">
        {tenant.name}
      </h1>
      <p class="mt-4 text-lg text-surface-600 leading-relaxed">
        {tenant.tagline}
      </p>
      <div class="mt-6 flex items-center gap-4 text-sm">
        <span class="flex items-center gap-1.5 text-surface-500">
          <svg class="w-4 h-4" style="color: {tenant.primaryColor}" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z"/>
            <path fill-rule="evenodd" d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3zm-3 4a1 1 0 100 2h.01a1 1 0 100-2H7zm3 0a1 1 0 100 2h3a1 1 0 100-2h-3z" clip-rule="evenodd"/>
          </svg>
          {productCount} products compared
        </span>
        <span class="flex items-center gap-1.5 text-surface-500">
          <svg class="w-4 h-4" style="color: {tenant.primaryColor}" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M5 2a1 1 0 011 1v1h1a1 1 0 010 2H6v1a1 1 0 01-2 0V6H3a1 1 0 010-2h1V3a1 1 0 011-1zm0 10a1 1 0 011 1v1h1a1 1 0 110 2H6v1a1 1 0 11-2 0v-1H3a1 1 0 110-2h1v-1a1 1 0 011-1zM12 2a1 1 0 01.967.744L14.146 7.2 17.5 9.134a1 1 0 010 1.732l-3.354 1.935-1.18 4.455a1 1 0 01-1.933 0L9.854 12.8 6.5 10.866a1 1 0 010-1.732l3.354-1.935 1.18-4.455A1 1 0 0112 2z" clip-rule="evenodd"/>
          </svg>
          Prices from 3 retailers
        </span>
      </div>
    </div>
  </div>
</section>
