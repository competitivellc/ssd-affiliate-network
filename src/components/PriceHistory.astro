---
import { getPriceHistory } from "@lib/db";
import { formatPrice } from "@lib/pricing";

export interface Props {
  productId: number;
  retailer: string;
}

const { productId, retailer } = Astro.props;
const { DB } = Astro.locals;
const history = await getPriceHistory(DB as any, productId, retailer, 30);
const minPrice = history.length > 0 ? Math.min(...history.map(h => h.price_cents)) : 0;
const maxPrice = history.length > 0 ? Math.max(...history.map(h => h.price_cents)) : 0;
const range = maxPrice - minPrice || 1;
---

<div class="rounded-xl border border-surface-200 p-4">
  <h4 class="text-sm font-semibold text-surface-700 mb-3">
    Price History &mdash; {retailer}
  </h4>
  {history.length > 0 ? (
    <div class="space-y-1">
      {history.map((point) => {
        const pct = ((point.price_cents - minPrice) / range) * 100;
        const isHigh = point.price_cents === maxPrice;
        const isLow = point.price_cents === minPrice;
        return (
          <div class="flex items-center gap-3 text-xs">
            <span class="w-24 text-surface-500 shrink-0">
              {new Date(point.recorded_at).toLocaleDateString("en-US", { month: "short", day: "numeric" })}
            </span>
            <div class="flex-1 h-5 bg-surface-100 rounded relative overflow-hidden">
              <div
                class={`h-full rounded transition-all spec-bar-fill ${isLow ? "bg-emerald-500" : isHigh ? "bg-red-400" : "bg-blue-400"}`}
                style={`width: ${pct}%`}
              ></div>
            </div>
            <span class={`w-20 text-right font-medium shrink-0 ${isLow ? "text-emerald-600" : isHigh ? "text-red-600" : "text-surface-700"}`}>
              {formatPrice(point.price_cents)}
            </span>
          </div>
        );
      })}
    </div>
  ) : (
    <p class="text-sm text-surface-400">No price history available yet.</p>
  )}
</div>
