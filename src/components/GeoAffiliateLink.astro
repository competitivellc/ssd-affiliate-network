---
import { rewriteAffiliateUrl } from "@lib/affiliate";
import { getAffiliateTag } from "@lib/db";

export interface Props {
  url: string;
  retailer: string;
  label: string;
  className?: string;
}

const { url, retailer, label, className = "" } = Astro.props;
const { DB, countryCode, tenant } = Astro.locals;
const tag = await getAffiliateTag(DB as any, tenant.id, retailer, countryCode);
const finalUrl = tag ? rewriteAffiliateUrl(url, tag, retailer) : url;
---

<a
  href={finalUrl}
  target="_blank"
  rel="noopener sponsored"
  class={`inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium rounded-lg border transition-colors ${className || "border-surface-200 text-surface-700 hover:bg-surface-50 hover:border-surface-300"}`}
>
  {retailer === "Amazon" && (
    <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="#FF9900">
      <path d="M13.483 0a.183.183 0 00-.061.013C5.768 2.576 0 8.84 0 15.299c0 6.46 4.427 9.194 9.43 9.194 3.463 0 6.897-1.499 9.194-3.398.134-.11.14-.304.014-.431l-1.303-1.303c-.108-.108-.28-.12-.401-.023-1.966 1.601-4.065 2.393-6.26 2.393-3.306 0-6.406-1.945-6.406-6.068 0-4.815 3.859-10.418 10.342-12.625a.19.19 0 00.117-.179V.66a.183.183 0 00-.104-.17.177.177 0 00-.07-.49z"/>
    </svg>
  )}
  {label}
  <svg class="w-3 h-3 text-surface-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
  </svg>
</a>
