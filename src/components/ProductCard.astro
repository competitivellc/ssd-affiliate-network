---
import type { Product, Price } from "@lib/db";
import { formatPrice, getLowestPrice } from "@lib/pricing";
import { getProductPrices } from "@lib/db";
import GeoAffiliateLink from "./GeoAffiliateLink.astro";

export interface Props {
  product: Product;
  rank?: number;
}

const { product, rank } = Astro.props;
const { DB } = Astro.locals;
const prices: Price[] = await getProductPrices(DB as any, product.id);
const lowestPrice = getLowestPrice(prices as any);
const scoreColor =
  product.overall_score >= 9
    ? "text-emerald-600 bg-emerald-50"
    : product.overall_score >= 8
    ? "text-blue-600 bg-blue-50"
    : "text-amber-600 bg-amber-50";

const isTopPick = rank === 1;
---

<a
  href={`/products/${product.slug}`}
  class="product-card flex flex-col justify-between h-full no-underline cursor-pointer relative rounded-xl border border-surface-200 bg-white p-4"
>
  <div class="aspect-[4/3] max-h-40 bg-surface-50 rounded-lg border border-surface-100 mb-2.5 flex items-center justify-center overflow-hidden">
    <svg class="w-8 h-8 text-surface-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/>
    </svg>
  </div>

  <div class="flex items-start justify-between mb-2">
    <div class="flex items-center gap-2 min-w-0">
      {rank && rank > 1 && (
        <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-surface-900 text-white text-xs font-bold shrink-0">
          #{rank}
        </span>
      )}
      {isTopPick && (
        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-amber-400 text-white text-xs font-bold shrink-0 shadow-sm">
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
          Top Pick
        </span>
      )}
      <div class="min-w-0">
        <p class="text-xs font-medium text-surface-500 uppercase tracking-wider">
          {product.brand_name}
        </p>
        <h3 class="text-sm font-semibold text-surface-900 transition-colors mt-0.5 line-clamp-2 leading-snug">
          {product.name}
        </h3>
      </div>
    </div>
    <div class={`inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-xs font-bold shrink-0 ${scoreColor}`}>
      <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
      </svg>
      {product.overall_score.toFixed(1)}/10
    </div>
  </div>

  <div class="grid grid-cols-2 gap-x-3 gap-y-1 mb-3 text-xs">
    <div class="flex items-center justify-between border-b border-surface-50 pb-1">
      <span class="text-surface-500">Capacity</span>
      <span class="font-medium text-surface-700">{(product.capacity_gb >= 1000 ? `${(product.capacity_gb / 1000).toFixed(0)}TB` : `${product.capacity_gb}GB`)}</span>
    </div>
    <div class="flex items-center justify-between border-b border-surface-50 pb-1">
      <span class="text-surface-500">Interface</span>
      <span class="font-medium text-surface-700">{product.interface}</span>
    </div>
    <div class="flex items-center justify-between col-span-2">
      <span class="text-surface-500">Read Speed</span>
      <span class="font-medium text-surface-700">{product.read_speed_mbps} MB/s</span>
    </div>
  </div>

  <div class="pt-2.5 border-t border-surface-100 space-y-1.5 mt-auto">
    {lowestPrice && (
      <div onclick="event.stopPropagation()">
        <GeoAffiliateLink
          url={lowestPrice.affiliate_url || "#"}
          retailer={lowestPrice.retailer}
          label="Click for Best Price"
          className="w-full justify-center py-2 text-sm font-semibold bg-blue-600 text-white border-blue-600 hover:bg-blue-700 [&_svg]:text-white"
        />
      </div>
    )}
    <span
      class="block text-center text-xs font-medium text-blue-600"
    >
      View Full Specs &rarr;
    </span>
  </div>
</a>
