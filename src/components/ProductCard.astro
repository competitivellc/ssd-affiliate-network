---
import type { Product, Price } from "@lib/db";
import { formatPrice, getLowestPrice } from "@lib/pricing";
import { getProductPrices } from "@lib/db";
import GeoAffiliateLink from "./GeoAffiliateLink.astro";

export interface Props {
  product: Product;
  rank?: number;
}

const { product, rank } = Astro.props;
const { DB } = Astro.locals;
const prices: Price[] = await getProductPrices(DB as any, product.id);
const lowestPrice = getLowestPrice(prices as any);
const scoreColor =
  product.overall_score >= 9
    ? "text-emerald-600 bg-emerald-50"
    : product.overall_score >= 8
    ? "text-blue-600 bg-blue-50"
    : "text-amber-600 bg-amber-50";
---

<div
  class="product-card block no-underline cursor-pointer"
  onclick={`location.href='/products/${product.slug}'`}
>
  <div class="flex items-start justify-between mb-3">
    <div class="flex items-center gap-2">
      {rank && (
        <span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-surface-900 text-white text-sm font-bold shrink-0">
          #{rank}
        </span>
      )}
      <div>
        <p class="text-xs font-medium text-surface-500 uppercase tracking-wider">
          {product.brand_name}
        </p>
        <h3 class="text-base font-semibold text-surface-900 transition-colors mt-0.5">
          {product.name}
        </h3>
      </div>
    </div>
    <div class={`inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-xs font-bold ${scoreColor}`}>
      <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
      </svg>
      {product.overall_score.toFixed(1)}
    </div>
  </div>

  <div class="space-y-1.5 mb-4">
    <div class="flex items-center justify-between text-xs">
      <span class="text-surface-500">Capacity</span>
      <span class="font-medium text-surface-700">{(product.capacity_gb >= 1000 ? `${(product.capacity_gb / 1000).toFixed(0)}TB` : `${product.capacity_gb}GB`)}</span>
    </div>
    <div class="flex items-center justify-between text-xs">
      <span class="text-surface-500">Interface</span>
      <span class="font-medium text-surface-700">{product.interface}</span>
    </div>
    <div class="flex items-center justify-between text-xs">
      <span class="text-surface-500">Read Speed</span>
      <span class="font-medium text-surface-700">{product.read_speed_mbps} MB/s</span>
    </div>
  </div>

  <div class="pt-3 border-t border-surface-100 space-y-2">
    {lowestPrice && (
      <div onclick="event.stopPropagation()">
        <GeoAffiliateLink
          url={lowestPrice.affiliate_url || "#"}
          retailer={lowestPrice.retailer}
          label="Click for Best Price"
          className="w-full justify-center py-2.5 text-sm bg-[#ef3737] text-white border-[#ef3737] hover:bg-[#d62f2f] [&_svg]:text-white"
        />
      </div>
    )}
    <a
      href={`/products/${product.slug}`}
      class="block text-center text-sm font-medium text-blue-600 hover:text-blue-700 no-underline"
      onclick="event.stopPropagation()"
    >
      View Details &rarr;
    </a>
  </div>
</div>
