---
import type { TenantConfig } from "@config/tenants";

export interface Props {
  tenant: TenantConfig;
}

const { tenant } = Astro.props;
const year = new Date().getFullYear();

const categories = tenant.id === "portablessds"
  ? [
      { label: "Ultra-Portable SSDs", href: "/compare?category=ultra-portable" },
      { label: "High-Speed SSDs", href: "/compare?category=high-speed" },
      { label: "Rugged SSDs", href: "/compare?category=rugged" },
    ]
  : [
      { label: "USB-C External SSDs", href: "/compare?category=usb-c" },
      { label: "Thunderbolt External SSDs", href: "/compare?category=thunderbolt" },
      { label: "Gaming External SSDs", href: "/compare?category=gaming" },
    ];

const hubLinks = tenant.id === "portablessds"
  ? [
      { label: "Best Portable SSD for Console Gaming", href: "/hubs/best-portable-ssd-for-console-gaming" },
      { label: "Fastest USB-C Portable SSDs", href: "/hubs/fastest-usb-c-portable-ssd" },
      { label: "Cheapest 1TB Portable SSD", href: "/hubs/cheapest-1tb-portable-ssd" },
    ]
  : [
      { label: "Best External SSD for PS5", href: "/hubs/best-ssd-for-ps5" },
      { label: "Fastest USB4 External Drives", href: "/hubs/fastest-usb4-external-ssd" },
      { label: "Cheapest 1TB External SSD", href: "/hubs/cheapest-1tb-external-ssd" },
    ];
---

<footer class="border-t border-surface-200 bg-surface-50 mt-16">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-8 mb-8">
      <div>
        <h3 class="text-xs font-semibold text-surface-800 uppercase tracking-wider mb-3">Site</h3>
        <ul class="space-y-2">
          <li><a href="/" class="text-sm text-surface-500 hover:text-surface-800 transition-colors">Home</a></li>
          <li><a href="/compare" class="text-sm text-surface-500 hover:text-surface-800 transition-colors">Compare SSDs</a></li>
          <li><a href="/hubs" class="text-sm text-surface-500 hover:text-surface-800 transition-colors">Buying Guides</a></li>
        </ul>
      </div>
      <div>
        <h3 class="text-xs font-semibold text-surface-800 uppercase tracking-wider mb-3">Categories</h3>
        <ul class="space-y-2">
          {categories.map((cat) => (
            <li><a href={cat.href} class="text-sm text-surface-500 hover:text-surface-800 transition-colors">{cat.label}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h3 class="text-xs font-semibold text-surface-800 uppercase tracking-wider mb-3">Buying Guides</h3>
        <ul class="space-y-2">
          {hubLinks.map((hub) => (
            <li><a href={hub.href} class="text-sm text-surface-500 hover:text-surface-800 transition-colors">{hub.label}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h3 class="text-xs font-semibold text-surface-800 uppercase tracking-wider mb-3">Company</h3>
        <ul class="space-y-2">
          <li><a href="/about" class="text-sm text-surface-500 hover:text-surface-800 transition-colors">About Us</a></li>
          <li><a href="/contact" class="text-sm text-surface-500 hover:text-surface-800 transition-colors">Contact</a></li>
          <li><a href="/editorial-methodology" class="text-sm text-surface-500 hover:text-surface-800 transition-colors">Editorial Methodology</a></li>
        </ul>
      </div>
      <div>
        <h3 class="text-xs font-semibold text-surface-800 uppercase tracking-wider mb-3">Legal</h3>
        <ul class="space-y-2">
          <li><a href="/privacy" class="text-sm text-surface-500 hover:text-surface-800 transition-colors">Privacy Policy</a></li>
          <li><a href="/terms" class="text-sm text-surface-500 hover:text-surface-800 transition-colors">Terms of Service</a></li>
        </ul>
      </div>
    </div>
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 border-t border-surface-200 pt-6">
      <p class="text-sm text-surface-500">
        &copy; {year} Competitive LLC. All rights reserved.
      </p>
      <div class="flex items-center gap-4 text-sm text-surface-500">
        <span>As an Amazon Associate we earn from qualifying purchases.</span>
      </div>
    </div>
  </div>
</footer>
