---
import BaseLayout from "@layouts/BaseLayout.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import GeoAffiliateLink from "@components/GeoAffiliateLink.astro";
import ProductGrid from "@components/ProductGrid.astro";
import { getProductBySlug, getProductPrices, getProductsByBrand, getRelatedProducts, getHubsForProduct } from "@lib/db";
import type { Hub } from "@lib/db";
import { classifyDrive } from "@lib/editorial";

export async function getStaticPaths() {
  return [];
}

const { DB, tenant, hostname } = Astro.locals;
const { slug } = Astro.params;
const db = DB!;

const product = await getProductBySlug(db, tenant.id, slug!);
if (!product) {
  return Astro.redirect("/404");
}

const prices = await getProductPrices(db, product.id);
const sortedPrices = [...prices].sort((a, b) => a.price_cents - b.price_cents);

const brandProducts = product.brand_id
  ? await getProductsByBrand(db, tenant.id, product.brand_id, product.id)
  : [];
const relatedProducts = product.category_id
  ? await getRelatedProducts(db, tenant.id, product.category_id, product.id)
  : [];
const productHubs: Hub[] = await getHubsForProduct(db, tenant.id, product, 4);

const scoreColor =
  product.overall_score >= 9
    ? "text-emerald-600"
    : product.overall_score >= 8
    ? "text-blue-600"
    : "text-amber-600";

const scoreBgColor =
  product.overall_score >= 9
    ? "bg-emerald-50"
    : product.overall_score >= 8
    ? "bg-blue-50"
    : "bg-amber-50";

const productUrl = `https://${hostname}/products/${product.slug}`;

const pros: string[] = product.pros ? JSON.parse(product.pros) : [];
const cons: string[] = product.cons ? JSON.parse(product.cons) : [];

const productJsonLd: Record<string, unknown> = {
  "@context": "https://schema.org/",
  "@type": "Product",
  "@id": productUrl,
  name: product.name,
  description: product.description,
  mpn: product.model || product.slug,
  ...(product.gtin13 ? { gtin13: product.gtin13 } : {}),
  brand: {
    "@type": "Brand",
    name: product.brand_name,
  },
  review: {
    "@type": "Review",
    author: {
      "@type": "Person",
      name: `${tenant.name} Testing Lab`,
    },
    reviewRating: {
      "@type": "Rating",
      ratingValue: product.overall_score.toFixed(1),
      bestRating: "10",
    },
    ...(pros.length > 0 && {
      positiveNotes: {
        "@type": "ItemList",
        itemListElement: pros.map((item, i) => ({
          "@type": "ListItem",
          position: i + 1,
          name: item,
        })),
      },
    }),
    ...(cons.length > 0 && {
      negativeNotes: {
        "@type": "ItemList",
        itemListElement: cons.map((item, i) => ({
          "@type": "ListItem",
          position: i + 1,
          name: item,
        })),
      },
    }),
  },
};

const archetype = classifyDrive(product);
const calloutBg: Record<string, string> = {
  "elite-pro-creator": "bg-purple-50 border-purple-200",
  "console-gaming": "bg-indigo-50 border-indigo-200",
  "rugged-portable": "bg-amber-50 border-amber-200",
  "highspeed-usb-pro": "bg-sky-50 border-sky-200",
  "budget-everyday": "bg-surface-50 border-surface-200",
};
const calloutText: Record<string, string> = {
  "elite-pro-creator": "text-purple-800",
  "console-gaming": "text-indigo-800",
  "rugged-portable": "text-amber-800",
  "highspeed-usb-pro": "text-sky-800",
  "budget-everyday": "text-surface-800",
};
---

<BaseLayout title={`${product.name} Review, Specs & Price`} description={product.description} jsonLd={productJsonLd}>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
    <div class="grid lg:grid-cols-3 gap-8">
      <div class="lg:col-span-2">
        <Breadcrumb
          items={[
            { label: "Home", href: "/" },
            ...(product.category_slug
              ? [{ label: product.category_name, href: `/compare?category=${product.category_slug}` }]
              : []),
            { label: product.name },
          ]}
        />

        <div class="flex items-start justify-between mb-6">
          <div>
            <p class="text-sm font-medium text-surface-500 uppercase tracking-wider">{product.brand_name}</p>
            <h1 class="text-2xl sm:text-3xl font-bold text-surface-900 mt-0.5">{product.name}</h1>
            {product.model && (
              <p class="text-sm text-surface-400 mt-1">Model: {product.model}</p>
            )}
          </div>
          <div class={`inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-bold ${scoreBgColor} ${scoreColor}`}>
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
            {product.overall_score.toFixed(1)}/10
          </div>
        </div>

        <div class="rounded-xl border border-surface-200 overflow-hidden mb-8">
          <table class="compare-grid">
            <tbody>
              <tr>
                <td class="font-medium text-surface-600 bg-surface-50/50 w-40">Capacity</td>
                <td class="text-surface-900 font-medium">{product.capacity_gb >= 1000 ? `${(product.capacity_gb / 1000).toFixed(0)}TB` : `${product.capacity_gb}GB`}</td>
              </tr>
              <tr>
                <td class="font-medium text-surface-600 bg-surface-50/50">Interface</td>
                <td class="text-surface-900">{product.interface}</td>
              </tr>
              <tr>
                <td class="font-medium text-surface-600 bg-surface-50/50">Form Factor</td>
                <td class="text-surface-900">{product.form_factor}</td>
              </tr>
              <tr>
                <td class="font-medium text-surface-600 bg-surface-50/50">Read Speed</td>
                <td class="text-surface-900 font-mono font-medium">{product.read_speed_mbps.toLocaleString()} MB/s</td>
              </tr>
              <tr>
                <td class="font-medium text-surface-600 bg-surface-50/50">Write Speed</td>
                <td class="text-surface-900 font-mono font-medium">{product.write_speed_mbps.toLocaleString()} MB/s</td>
              </tr>
              <tr>
                <td class="font-medium text-surface-600 bg-surface-50/50">Endurance (TBW)</td>
                <td class="text-surface-900">{product.tbw.toLocaleString()} TB</td>
              </tr>
              <tr>
                <td class="font-medium text-surface-600 bg-surface-50/50">Warranty</td>
                <td class="text-surface-900">{product.warranty_years} Years</td>
              </tr>
            </tbody>
          </table>
        </div>

        {product.description && (
          <section class="mb-6">
            <h2 class="text-xl font-semibold text-surface-900 mb-3">Overview</h2>
            <p class="text-surface-600 leading-relaxed">{product.description}</p>
            <p class="text-sm text-surface-500 mt-2">
              See how it stacks up against competitors in our <a href={`/compare?category=${product.category_slug}`} class="text-blue-600 hover:text-blue-700 font-medium">{product.category_name} SSD comparison</a>, or browse related <a href="/hubs" class="text-blue-600 hover:text-blue-700 font-medium">SSD buying guides</a>.
            </p>
          </section>
        )}

        <div class="grid sm:grid-cols-2 gap-6 mb-8">
          {pros.length > 0 && (
            <div class="rounded-xl border border-emerald-200 bg-emerald-50/50 p-4">
              <h3 class="text-sm font-semibold text-emerald-800 mb-2">Pros</h3>
              <ul class="space-y-1">
                {pros.map((pro: string) => (
                  <li class="flex items-start gap-2 text-sm text-emerald-700">
                    <svg class="w-4 h-4 mt-0.5 shrink-0 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                    </svg>
                    {pro}
                  </li>
                ))}
              </ul>
            </div>
          )}
          {cons.length > 0 && (
            <div class="rounded-xl border border-red-200 bg-red-50/50 p-4">
              <h3 class="text-sm font-semibold text-red-800 mb-2">Cons</h3>
              <ul class="space-y-1">
                {cons.map((con: string) => (
                  <li class="flex items-start gap-2 text-sm text-red-700">
                    <svg class="w-4 h-4 mt-0.5 shrink-0 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                    {con}
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>

        <section class="mb-8 space-y-5">
          <div>
            <h2 class="text-xl font-semibold text-surface-900 mb-1">{archetype.label} Analysis</h2>
            <p class="text-surface-500 leading-relaxed">{archetype.tagline}</p>
          </div>

          {archetype.blocks.map((block) => (
            <>
              {block.type === "prose" && (
                <div>
                  {block.title && (
                    <h3 class="text-base font-semibold text-surface-800 mb-1.5">{block.title}</h3>
                  )}
                  <p class="text-surface-600 leading-relaxed">{block.content}</p>
                </div>
              )}
              {block.type === "bullets" && (
                <div>
                  {block.title && (
                    <h3 class="text-base font-semibold text-surface-800 mb-1.5">{block.title}</h3>
                  )}
                  <ul class="space-y-1">
                    {block.items.map((item) => (
                      <li class="flex items-start gap-2 text-sm text-surface-600">
                        <svg class="w-4 h-4 mt-0.5 shrink-0 text-surface-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                        </svg>
                        {item}
                      </li>
                    ))}
                  </ul>
                </div>
              )}
              {block.type === "callout" && (
                <div class={`rounded-lg border ${calloutBg[archetype.id]} px-4 py-3`}>
                  <p class={`text-sm ${calloutText[archetype.id]}`}>{block.content}</p>
                </div>
              )}
            </>
          ))}
        </section>

        {brandProducts.length > 0 && (
          <section class="mb-8">
            <div class="flex items-center justify-between mb-4">
              <h2 class="text-xl font-semibold text-surface-900">More {product.brand_name} SSDs</h2>
              <a
                href={`/compare?category=${product.category_slug}`}
                class="text-sm font-medium text-blue-600 hover:text-blue-700"
              >
                View all &rarr;
              </a>
            </div>
            <ProductGrid products={brandProducts} />
          </section>
        )}

        {relatedProducts.length > 0 && (
          <section class="mb-8">
            <div class="flex items-center justify-between mb-4">
              <h2 class="text-xl font-semibold text-surface-900">Alternative {product.category_name}</h2>
              <a
                href={`/compare?category=${product.category_slug}`}
                class="text-sm font-medium text-blue-600 hover:text-blue-700"
              >
                Compare all &rarr;
              </a>
            </div>
            <ProductGrid products={relatedProducts} />
          </section>
        )}

        {productHubs.length > 0 && (
          <section class="mb-8">
            <div class="flex items-center justify-between mb-3">
              <h2 class="text-base font-semibold text-surface-900">Featured In</h2>
            </div>
            <div class="space-y-2">
              {productHubs.map((h) => (
                <a
                  href={`/hubs/${h.slug}`}
                  class="flex items-center gap-2 text-sm text-blue-600 hover:text-blue-700 no-underline group"
                >
                  <svg class="w-4 h-4 shrink-0 text-surface-400 group-hover:text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
                  </svg>
                  <span>{h.name}</span>
                  <svg class="w-3 h-3 ml-auto group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                  </svg>
                </a>
              ))}
            </div>
          </section>
        )}

      </div>

      <div class="lg:col-span-1">
        <div class="sticky top-8 space-y-4">
          {sortedPrices[0] && (
            <GeoAffiliateLink
              url={sortedPrices[0].affiliate_url || "#"}
              retailer={sortedPrices[0].retailer}
              label="Click for Best Price"
              className="w-full justify-center py-3 text-sm bg-[#ef3737] text-white border-[#ef3737] hover:bg-[#d62f2f] [&_svg]:text-white"
            />
          )}

          <div class="rounded-xl border border-surface-200 p-5">
            <h3 class="text-sm font-semibold text-surface-700 mb-3">Quick Specs</h3>
            <div class="space-y-3">
              <div>
                <div class="flex justify-between text-xs text-surface-500 mb-1">
                  <span>Read Speed</span>
                  <span class="font-mono font-medium text-surface-700">{product.read_speed_mbps} MB/s</span>
                </div>
                <div class="spec-bar">
                  <div class="spec-bar-fill bg-blue-500" style={`width: ${Math.min(100, (product.read_speed_mbps / 3000) * 100)}%`}></div>
                </div>
              </div>
              <div>
                <div class="flex justify-between text-xs text-surface-500 mb-1">
                  <span>Write Speed</span>
                  <span class="font-mono font-medium text-surface-700">{product.write_speed_mbps} MB/s</span>
                </div>
                <div class="spec-bar">
                  <div class="spec-bar-fill bg-emerald-500" style={`width: ${Math.min(100, (product.write_speed_mbps / 3000) * 100)}%`}></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
