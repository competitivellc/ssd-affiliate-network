---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout title="Page Not Found">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-24 text-center">
    <h1 class="text-6xl font-bold text-surface-200 mb-4">404</h1>
    <p class="text-xl text-surface-600 mb-8">Page not found</p>
    <a href="/" class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-medium text-white rounded-lg" style="background-color: var(--color-primary)">
      Go Home
    </a>
  </div>
</BaseLayout>
