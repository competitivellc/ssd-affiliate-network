---
import BaseLayout from "@layouts/BaseLayout.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import ProductGrid from "@components/ProductGrid.astro";
import GeoAffiliateLink from "@components/GeoAffiliateLink.astro";
import {
  getHubBySlug,
  getHubProducts,
  getProductPrices,
  getRelatedHubs,
  getHubsByType,
} from "@lib/db";
import type { Hub, Product, FilterCriteria, Price } from "@lib/db";
import { formatPrice, getLowestPrice } from "@lib/pricing";
import { getHubEditorial } from "@lib/hubs";
import type { HubEditorial } from "@lib/hubs";

export async function getStaticPaths() {
  return [];
}

const { DB, tenant, hostname } = Astro.locals;
const { slug } = Astro.params;
const db = DB!;

const hub: Hub | null = await getHubBySlug(db, tenant.id, slug!);
if (!hub) {
  return Astro.redirect("/404");
}

const filterCriteria: FilterCriteria = JSON.parse(hub.filter_criteria || "{}");

let products: Product[];
let productPrices: Record<number, Price[]> = {};

if (hub.hub_type === "value") {
  const all = await getHubProducts(db, tenant.id, {
    ...filterCriteria,
    sort: undefined,
  });
  const pricePromises = all.map(async (p) => {
    const prices = await getProductPrices(db, p.id);
    productPrices[p.id] = prices;
    return { ...p, _lowestPrice: prices.length > 0 ? Math.min(...prices.map((pr) => pr.price_cents)) : Infinity };
  });
  const withPrices = await Promise.all(pricePromises);
  withPrices.sort((a, b) => (a._lowestPrice || 0) - (b._lowestPrice || 0));
  products = withPrices.slice(0, filterCriteria.limit || 20);
} else {
  products = await getHubProducts(db, tenant.id, filterCriteria);
  const pricePromises = products.map(async (p) => {
    productPrices[p.id] = await getProductPrices(db, p.id);
  });
  await Promise.all(pricePromises);
}

const editorial: HubEditorial | null = getHubEditorial(hub.hub_type, products, hub.name);

const relatedHubs: Hub[] = await getRelatedHubs(db, tenant.id, hub.slug, 6);
const complementaryType = hub.hub_type === "use-case" ? "performance" : hub.hub_type === "performance" ? "value" : "use-case";
const complementaryHubs: Hub[] = (await getHubsByType(db, tenant.id, complementaryType)).slice(0, 3);

const ctayLabels: Record<string, string> = {
  "use-case": "Not Sure Which External SSD to Choose?",
  performance: "Need More Performance Data?",
  value: "Looking for the Best Deal?",
};

const hubTypeLabels: Record<string, string> = {
  "use-case": "Use-Case Guide",
  performance: "Performance Rankings",
  value: "Value Rankings",
};

const accentStyle = { backgroundColor: tenant.primaryColor };
const title = hub.h1 || hub.name;
const metaDesc = hub.meta_description || hub.description || "";

const hubUrl = `https://${hostname}/hubs/${hub.slug}`;
const hubJsonLd = {
  "@context": "https://schema.org/",
  "@type": "CollectionPage",
  "@id": hubUrl,
  name: hub.name,
  description: metaDesc,
  url: hubUrl,
  mainEntity: {
    "@type": "ItemList",
    itemListElement: products.map((p, i) => ({
      "@type": "ListItem",
      position: i + 1,
      item: {
        "@type": "Product",
        name: p.name,
        url: `https://${hostname}/products/${p.slug}`,
        mpn: p.model || p.slug,
        ...(p.gtin13 ? { gtin13: p.gtin13 } : {}),
      },
    })),
  },
};
---

<BaseLayout title={title} description={metaDesc} jsonLd={hubJsonLd}>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumb
      items={[
        { label: "Home", href: "/" },
        { label: hubTypeLabels[hub.hub_type], href: "/hubs" },
        { label: hub.name },
      ]}
    />

    <div class="mb-8">
      <p class="text-sm font-medium text-surface-500 uppercase tracking-wider">
        {hubTypeLabels[hub.hub_type]}
      </p>
      <h1 class="text-2xl sm:text-3xl font-bold text-surface-900 mt-1">{hub.h1 || hub.name}</h1>
      {hub.description && (
        <p class="text-surface-600 mt-2 max-w-3xl">{hub.description}</p>
      )}
    </div>

    {hub.intro_html && (
      <div class="prose prose-surface max-w-3xl mb-8 text-surface-600 leading-relaxed" set:html={hub.intro_html} />
    )}

    {products.length === 0 && (
      <div class="rounded-xl border border-surface-200 p-8 text-center">
        <p class="text-surface-500">No products found for this category.</p>
      </div>
    )}

    {products.length > 0 && (
      <>
        <section class="mb-8">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-1 h-6 rounded-full" style={accentStyle}></div>
            <h2 class="text-xl font-bold text-surface-900">{hub.hub_type === "value" ? "Ranked by Price" : "Ranked by Score"}</h2>
          </div>
          <ProductGrid products={products} showRank />
        </section>

        {editorial && editorial.summary && (
          <section class="rounded-xl border border-surface-200 p-6 mb-8">
            <div class="flex items-start gap-3 mb-4">
              <div class="w-1 h-6 rounded-full mt-1" style={accentStyle}></div>
              <div>
                <h2 class="text-lg font-semibold text-surface-900">Our Take</h2>
                <p class="text-surface-600 mt-2 leading-relaxed" set:html={editorial.summary} />
              </div>
            </div>
          </section>
        )}

        {editorial?.blocks?.map((block) => (
          <>
            {block.type === "prose" && (
              <section class="mb-6">
                {block.title && (
                  <h3 class="text-base font-semibold text-surface-800 mb-2" set:html={block.title} />
                )}
                <p class="text-surface-600 leading-relaxed" set:html={block.content} />
              </section>
            )}
            {block.type === "bullets" && block.items && (
              <section class="mb-6">
                {block.title && (
                  <h3 class="text-base font-semibold text-surface-800 mb-2" set:html={block.title} />
                )}
                <ul class="space-y-2">
                  {block.items.map((item) => (
                    <li class="flex items-start gap-2 text-sm text-surface-600">
                      <svg class="w-4 h-4 mt-0.5 shrink-0 text-surface-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                      </svg>
                      {item}
                    </li>
                  ))}
                </ul>
              </section>
            )}
            {block.type === "callout" && block.content && (
              <div class="rounded-lg border border-surface-200 bg-surface-50 px-4 py-3 mb-6">
                <p class="text-sm text-surface-700 leading-relaxed" set:html={block.content} />
              </div>
            )}
            {block.type === "comparison" && block.rows && (
              <section class="mb-6">
                {block.title && (
                  <h3 class="text-base font-semibold text-surface-800 mb-3">{block.title}</h3>
                )}
                <div class="overflow-x-auto rounded-xl border border-surface-200">
                  <table class="min-w-full text-sm">
                    <thead>
                      <tr class="bg-surface-50">
                        <th class="text-left px-4 py-2.5 font-medium text-surface-600">Drive</th>
                        <th class="text-left px-4 py-2.5 font-medium text-surface-600">Read Speed</th>
                        <th class="text-left px-4 py-2.5 font-medium text-surface-600">Write Speed</th>
                        <th class="text-left px-4 py-2.5 font-medium text-surface-600">Interface</th>
                      </tr>
                    </thead>
                    <tbody>
                      {block.rows.map((row, i) => (
                        <tr class={i % 2 === 0 ? "" : "bg-surface-50/50"}>
                          <td class="px-4 py-2.5 font-medium text-surface-900">{row.label}</td>
                          {row.values.map((v) => (
                            <td class="px-4 py-2.5 text-surface-600">{v}</td>
                          ))}
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </section>
            )}
          </>
        ))}

        {hub.hub_type === "value" && products.length > 0 && (
          <section class="mb-8">
            <h3 class="text-base font-semibold text-surface-800 mb-3">Price Overview</h3>
            <div class="overflow-x-auto rounded-xl border border-surface-200">
              <table class="min-w-full text-sm">
                <thead>
                  <tr class="bg-surface-50">
                    <th class="text-left px-4 py-2.5 font-medium text-surface-600">Drive</th>
                    <th class="text-left px-4 py-2.5 font-medium text-surface-600">Capacity</th>
                    <th class="text-left px-4 py-2.5 font-medium text-surface-600">Lowest Price</th>
                    <th class="text-left px-4 py-2.5 font-medium text-surface-600">Retailer</th>
                  </tr>
                </thead>
                <tbody>
                  {products.map((p, i) => {
                    const prices = productPrices[p.id] || [];
                    const lowest = getLowestPrice(prices as any);
                    return (
                      <tr class={i % 2 === 0 ? "" : "bg-surface-50/50"}>
                        <td class="px-4 py-2.5 font-medium text-surface-900">{p.name}</td>
                        <td class="px-4 py-2.5 text-surface-600">
                          {p.capacity_gb >= 1000
                            ? `${(p.capacity_gb / 1000).toFixed(0)}TB`
                            : `${p.capacity_gb}GB`}
                        </td>
                        <td class="px-4 py-2.5 font-mono font-medium text-surface-900">
                          {lowest ? formatPrice(lowest.price_cents, "USD") : "—"}
                        </td>
                        <td class="px-4 py-2.5">
                          {lowest?.affiliate_url ? (
                            <GeoAffiliateLink
                              url={lowest.affiliate_url}
                              retailer={lowest.retailer}
                              label={`Buy at ${lowest.retailer}`}
                              className="inline-flex items-center gap-1 text-sm font-medium text-blue-600 hover:text-blue-700 no-underline"
                            />
                          ) : (
                            <span class="text-surface-400">—</span>
                          )}
                        </td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            </div>
          </section>
        )}

        {complementaryHubs.length > 0 && (
          <section class="mb-8">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-1 h-6 rounded-full" style={accentStyle}></div>
              <h3 class="text-base font-semibold text-surface-900">
                {hub.hub_type === "use-case" ? "Performance & Value Data" : hub.hub_type === "performance" ? "Value Comparisons" : "Performance Rankings"}
              </h3>
            </div>
            <p class="text-surface-600 text-sm leading-relaxed mb-3">
              {hub.hub_type === "use-case"
                ? `To see how these drives compare by raw speed and throughput, review the detailed benchmarks in our `
                : hub.hub_type === "performance"
                  ? `Find the best bang for your buck — the same drives sorted by price-to-performance ratio in our `
                  : `For a complete ranking of these drives by features, speed, and overall score, browse our `}
              {(() => {
                const linkHubs = complementaryHubs.slice(0, 2);
                return linkHubs.map((ch, i) => (
                  <><a href={`/hubs/${ch.slug}`} class="text-blue-600 hover:text-blue-700 font-medium">{ch.name}</a>{i < linkHubs.length - 1 ? " or " : ""}</>
                ));
              })()}
              {hub.hub_type === "use-case" ? " guide." : hub.hub_type === "performance" ? " value guide." : " performance guide."}
            </p>
          </section>
        )}

        {relatedHubs.length > 0 && (
          <section class="mb-8">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-1 h-6 rounded-full" style={accentStyle}></div>
              <h2 class="text-lg font-semibold text-surface-900">Related Buying Guides & Rankings</h2>
            </div>
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
              {relatedHubs.map((rh) => (
                <a
                  href={`/hubs/${rh.slug}`}
                  class="rounded-xl border border-surface-200 p-4 hover:shadow-md hover:-translate-y-0.5 transition-all no-underline group"
                >
                  <p class="text-xs font-medium text-surface-400 uppercase tracking-wider mb-1">
                    {rh.hub_type === "use-case" ? "Buying Guide" : rh.hub_type === "performance" ? "Performance" : "Value"}
                  </p>
                  <h3 class="text-sm font-semibold text-surface-900 group-hover:text-blue-600 transition-colors">{rh.name}</h3>
                  {rh.description && (
                    <p class="mt-1 text-xs text-surface-500 line-clamp-2">{rh.description}</p>
                  )}
                </a>
              ))}
            </div>
          </section>
        )}

        <section class="rounded-xl border border-surface-200 p-5 mb-8">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-1 h-6 rounded-full" style={accentStyle}></div>
            <h3 class="text-base font-semibold text-surface-900">{ctayLabels[hub.hub_type]}</h3>
          </div>
          <p class="text-surface-600 leading-relaxed text-sm">
            Visit our <a href="/compare" class="text-blue-600 hover:text-blue-700 no-underline font-medium">spec comparison tool</a> to compare drives side-by-side, or browse our <a href="/hubs" class="text-blue-600 hover:text-blue-700 no-underline font-medium">full library of buying guides and rankings</a>.
          </p>
          {complementaryHubs.length > 0 && (
            <p class="text-surface-600 leading-relaxed text-sm mt-2">
              {hub.hub_type === "use-case"
                ? `You may also want to read our performance-focused `
                : hub.hub_type === "performance"
                  ? `Pair this guide with our value-focused `
                  : `See top-rated drives in our `}
              {complementaryHubs.slice(0, 2).map((ch, i) => (
                <><a href={`/hubs/${ch.slug}`} class="text-blue-600 hover:text-blue-700 no-underline font-medium">{ch.name.toLowerCase().includes("ssd") ? ch.name : `${ch.name} guide`}</a>{i < Math.min(complementaryHubs.length, 2) - 1 ? " or " : ""}</>
              ))}.
            </p>
          )}
        </section>
      </>
    )}
  </div>
</BaseLayout>
