---
import BaseLayout from "@layouts/BaseLayout.astro";
import HeroSection from "@components/HeroSection.astro";
import ProductGrid from "@components/ProductGrid.astro";
import { getTopRatedProducts, getAllProducts, getCategoriesBySite, getLastUpdatedDate, getHubsBySite } from "@lib/db";
import type { Product, Hub } from "@lib/db";

const { DB, tenant } = Astro.locals;
const db = DB!;
const [topRated, allProducts, categories, lastUpdated, hubs] = await Promise.all([
  getTopRatedProducts(db, tenant.id, 3),
  getAllProducts(db, tenant.id),
  getCategoriesBySite(db, tenant.id),
  getLastUpdatedDate(db, tenant.id),
  getHubsBySite(db, tenant.id),
]);
const byHubType: Record<string, Hub[]> = { "use-case": [], performance: [], value: [] };
for (const h of hubs) { byHubType[h.hub_type]?.push(h); }
const accentStyle = { backgroundColor: tenant.primaryColor };
const year = new Date().getFullYear();
---

<BaseLayout title={tenant.id === "portablessds" ? `Top Portable SSDs ${year} - Expert Reviews, Prices & Comparisons` : `Best External SSDs ${year} - Expert Reviews, Prices & Comparisons`}>
  <HeroSection tenant={tenant} productCount={allProducts.length} lastUpdated={lastUpdated} />

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12">
    <nav class="flex flex-wrap items-center gap-2 mb-10 pb-6 border-b border-surface-100" aria-label="Quick navigation">
      <span class="text-xs font-semibold text-surface-400 uppercase tracking-wider mr-1">Quick links:</span>
      <a href="/compare" class="px-3 py-1.5 text-xs font-medium rounded-lg border border-surface-200 text-surface-600 hover:bg-surface-50 transition-colors">Compare SSDs</a>
      <a href="/hubs" class="px-3 py-1.5 text-xs font-medium rounded-lg border border-surface-200 text-surface-600 hover:bg-surface-50 transition-colors">Buying Guides</a>
      <a href="/about" class="px-3 py-1.5 text-xs font-medium rounded-lg border border-surface-200 text-surface-600 hover:bg-surface-50 transition-colors">About Us</a>
      {categories.slice(0, 3).map((cat) => (
        <a href={`/compare?category=${cat.slug}`} class="px-3 py-1.5 text-xs font-medium rounded-lg border border-surface-200 text-surface-600 hover:bg-surface-50 transition-colors">{cat.name}</a>
      ))}
    </nav>

    <section class="mb-12 grid gap-3 sm:grid-cols-3 text-sm">
      <a href="/compare" class="flex items-center gap-2 rounded-lg border border-surface-200 p-3 hover:bg-surface-50 transition-colors no-underline">
        <span class="w-8 h-8 rounded-full bg-blue-100 text-blue-700 flex items-center justify-center text-xs font-bold shrink-0">1</span>
        <span class="text-surface-700 font-medium">Compare all external SSDs side-by-side &rarr;</span>
      </a>
      <a href="/hubs/best-ssd-for-ps5" class="flex items-center gap-2 rounded-lg border border-surface-200 p-3 hover:bg-surface-50 transition-colors no-underline">
        <span class="w-8 h-8 rounded-full bg-indigo-100 text-indigo-700 flex items-center justify-center text-xs font-bold shrink-0">2</span>
        <span class="text-surface-700 font-medium">Best external SSD for PS5 gaming &rarr;</span>
      </a>
      <a href="/hubs/cheapest-1tb-external-ssd" class="flex items-center gap-2 rounded-lg border border-surface-200 p-3 hover:bg-surface-50 transition-colors no-underline">
        <span class="w-8 h-8 rounded-full bg-emerald-100 text-emerald-700 flex items-center justify-center text-xs font-bold shrink-0">3</span>
        <span class="text-surface-700 font-medium">Cheapest 1TB external SSDs ranked &rarr;</span>
      </a>
    </section>

    {topRated.length > 0 && (
      <section class="mb-16">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-1 h-6 rounded-full" style={accentStyle}></div>
          <h2 class="text-2xl font-bold text-surface-900">Best {tenant.name}</h2>
        </div>
        <ProductGrid products={topRated} showRank />
      </section>
    )}

    <section class="mb-16">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-1 h-6 rounded-full" style={accentStyle}></div>
        <h2 class="text-2xl font-bold text-surface-900">Browse by Category</h2>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {categories.map((cat) => (
          <a
            href={`/compare?category=${cat.slug}`}
            class="rounded-xl border border-surface-200 p-5 hover:shadow-md hover:-translate-y-0.5 transition-all no-underline group flex flex-col"
          >
            <h3 class="text-base font-semibold text-surface-900 group-hover:text-blue-600 transition-colors">{cat.name}</h3>
            {cat.description && (
              <p class="mt-1 text-sm text-surface-500 flex-1">{cat.description}</p>
            )}
            <span class="mt-3 inline-flex items-center gap-1 text-xs font-medium text-blue-600 opacity-0 group-hover:opacity-100 transition-opacity">
              Compare {cat.name}
              <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </span>
          </a>
        ))}
      </div>
    </section>

    {allProducts.length > 3 && (
      <section class="mb-16">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-1 h-6 rounded-full" style={accentStyle}></div>
          <h2 class="text-2xl font-bold text-surface-900">All {tenant.name} — {allProducts.length} Drives</h2>
        </div>
        <ProductGrid products={allProducts} />
        <div class="mt-4 text-sm text-surface-500 text-center">
          See individual reviews:
          {allProducts.slice(0, 5).map((p, i) => (
            <><a href={`/products/${p.slug}`} class="text-blue-600 hover:text-blue-700 font-medium">{p.name}</a>{i < Math.min(allProducts.length, 5) - 1 ? ", " : ""}</>
          ))}
          {allProducts.length > 5 && <> and <a href="/compare" class="text-blue-600 hover:text-blue-700 font-medium">compare all {allProducts.length} drives</a></>}
        </div>
      </section>
    )}

    {byHubType["use-case"]?.length > 0 && (
      <section class="mb-16">
        <div class="flex items-center gap-3 mb-2">
          <div class="w-1 h-6 rounded-full" style={accentStyle}></div>
          <h2 class="text-2xl font-bold text-surface-900">Buying Guides</h2>
        </div>
        <p class="text-surface-500 text-sm mb-4">Find the best external SSD for your specific needs.</p>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {byHubType["use-case"].map((hub) => (
            <a
              href={`/hubs/${hub.slug}`}
              class="rounded-xl border border-surface-200 p-5 hover:shadow-md hover:-translate-y-0.5 transition-all no-underline group flex flex-col"
            >
              <h3 class="text-base font-semibold text-surface-900 group-hover:text-blue-600 transition-colors">{hub.name}</h3>
              {hub.description && (
                <p class="mt-1 text-sm text-surface-500 line-clamp-2 flex-1">{hub.description}</p>
              )}
            </a>
          ))}
        </div>
        <div class="mt-6 text-center">
          <a href="/hubs" class="inline-flex items-center gap-1.5 text-sm font-medium text-blue-600 hover:text-blue-700 transition-colors">
            Browse All Buying Guides & Ranked Lists
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>
      </section>
    )}

    <section class="mb-16">
      <div class="flex items-center gap-3 mb-2">
        <div class="w-1 h-6 rounded-full" style={accentStyle}></div>
        <h2 class="text-2xl font-bold text-surface-900">Popular Comparisons</h2>
      </div>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 text-sm">
        <a href="/compare?category=usb-c" class="rounded-lg border border-surface-200 p-3 hover:bg-surface-50 transition-colors no-underline text-surface-700 font-medium flex items-center min-h-[44px]">USB-C External SSDs Compared</a>
        <a href="/compare?category=thunderbolt" class="rounded-lg border border-surface-200 p-3 hover:bg-surface-50 transition-colors no-underline text-surface-700 font-medium flex items-center min-h-[44px]">Thunderbolt External SSDs Compared</a>
        <a href="/compare?category=gaming" class="rounded-lg border border-surface-200 p-3 hover:bg-surface-50 transition-colors no-underline text-surface-700 font-medium flex items-center min-h-[44px]">Gaming External SSDs Compared</a>
        <a href="/compare" class="rounded-lg border border-surface-200 p-3 hover:bg-surface-50 transition-colors no-underline text-surface-700 font-medium flex items-center min-h-[44px]">All SSDs Side-by-Side</a>
      </div>
    </section>

    {(byHubType["performance"]?.length > 0 || byHubType["value"]?.length > 0) && (
      <section class="mb-16">
        <div class="flex items-center gap-3 mb-2">
          <div class="w-1 h-6 rounded-full" style={accentStyle}></div>
          <h2 class="text-2xl font-bold text-surface-900">Rankings & Comparisons</h2>
        </div>
        <p class="text-surface-500 text-sm mb-4">Performance rankings and value comparisons to help you decide.</p>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {[...(byHubType["performance"] || []), ...(byHubType["value"] || [])].map((hub) => (
            <a
              href={`/hubs/${hub.slug}`}
              class="rounded-xl border border-surface-200 p-5 hover:shadow-md hover:-translate-y-0.5 transition-all no-underline group flex flex-col"
            >
              <h3 class="text-base font-semibold text-surface-900 group-hover:text-blue-600 transition-colors">{hub.name}</h3>
              {hub.description && (
                <p class="mt-1 text-sm text-surface-500 line-clamp-2 flex-1">{hub.description}</p>
              )}
            </a>
          ))}
        </div>
        <div class="mt-6 text-center">
          <a href="/hubs" class="inline-flex items-center gap-1.5 text-sm font-medium text-blue-600 hover:text-blue-700 transition-colors">
            View All Performance & Value Rankings
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>
      </section>
    )}

  </div>
</BaseLayout>
