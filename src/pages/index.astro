---
import BaseLayout from "@layouts/BaseLayout.astro";
import HeroSection from "@components/HeroSection.astro";
import ProductGrid from "@components/ProductGrid.astro";
import { getFeaturedProducts, getAllProducts, getCategoriesBySite } from "@lib/db";
import type { Product } from "@lib/db";

const { DB, tenant } = Astro.locals;
const db = DB!;
const [featured, allProducts, categories] = await Promise.all([
  getFeaturedProducts(db, tenant.id),
  getAllProducts(db, tenant.id),
  getCategoriesBySite(db, tenant.id),
]);
const accentStyle = { backgroundColor: tenant.primaryColor };
---

<BaseLayout title="Compare & Review Top SSDs">
  <HeroSection tenant={tenant} productCount={allProducts.length} />

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12">
    {featured.length > 0 && (
      <section class="mb-16">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-1 h-6 rounded-full" style={accentStyle}></div>
          <h2 class="text-2xl font-bold text-surface-900">Featured Picks</h2>
        </div>
        <ProductGrid products={featured} />
      </section>
    )}

    <section class="mb-16">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-1 h-6 rounded-full" style={accentStyle}></div>
        <h2 class="text-2xl font-bold text-surface-900">Browse by Category</h2>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {categories.map((cat) => (
          <a
            href={`/compare?category=${cat.slug}`}
            class="rounded-xl border border-surface-200 p-5 hover:shadow-md hover:-translate-y-0.5 transition-all no-underline group"
          >
            <h3 class="text-base font-semibold text-surface-900">{cat.name}</h3>
            {cat.description && (
              <p class="mt-1 text-sm text-surface-500">{cat.description}</p>
            )}
          </a>
        ))}
      </div>
    </section>

    <section>
      <div class="flex items-center gap-3 mb-6">
        <div class="w-1 h-6 rounded-full" style={accentStyle}></div>
        <h2 class="text-2xl font-bold text-surface-900">All Products</h2>
      </div>
      <ProductGrid products={allProducts} />
    </section>
  </div>
</BaseLayout>
